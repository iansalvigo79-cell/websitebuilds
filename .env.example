# Supabase
# Get from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for Admin: Scores (save actual goals, compute from games, calculate points)
# Get from Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: protect /api/admin/calculate-points with a secret header
# ADMIN_SECRET=your-admin-secret

# Stripe (optional, for subscriptions)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: app URL for Stripe redirects
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
